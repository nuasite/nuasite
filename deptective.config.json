{
	"checkDevDependencies": true,
	"packageOverrides": {
		"@nuasite/nua": {
			"allowedUnusedDependencies": [
				"@astrojs/check",
				"@nuasite/cli",
				"@nuasite/components",
				"@nuasite/core",
				"@nuasite/llm-enhancements",
				"@tailwindcss/typography",
				"flowbite",
				"tailwindcss",
				"typescript",
				"vite"
			]
		},
		"@nuasite/cms": {
			"excludePatterns": ["**/*.d.ts", "**/generated/**", "src/editor/**", "src/admin/**"],
			"testPatterns": ["**/*.test.*", "**/*.spec.*", "**/__tests__/**", "**/test/**", "src/index.ts"]
		},
		"@nuasite/cms-studio": {
			"excludePatterns": ["**/*.d.ts", "src/spa/**", "vite.config.ts"]
		},
		"playground": {
			"allowedUnusedDependencies": ["@nuasite/nua"]
		}
	}
}
