{
	"name": "@nuasite/cms-mdx-editor",
	"description": "React MDX body editor (Milkdown) for Nua CMS collection entries — round-trips component blocks, props, children and imports. Consumed by collections-admin and the webmaster collections tab.",
	"files": [
		"dist/**",
		"src/**",
		"README.md",
		"package.json"
	],
	"homepage": "https://github.com/nuasite/nuasite/blob/main/packages/cms-mdx-editor/README.md",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nuasite/nuasite.git",
		"directory": "packages/cms-mdx-editor"
	},
	"license": "Apache-2.0",
	"version": "0.43.0-beta.6",
	"module": "src/index.ts",
	"types": "src/index.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"dependencies": {
		"@milkdown/core": "catalog:editor",
		"@milkdown/plugin-listener": "catalog:editor",
		"@milkdown/preset-commonmark": "catalog:editor",
		"@milkdown/preset-gfm": "catalog:editor",
		"@milkdown/utils": "catalog:editor",
		"@nuasite/cms-types": "workspace:*",
		"remark-mdx": "catalog:editor",
		"remark-parse": "catalog:editor",
		"unified": "catalog:editor"
	},
	"devDependencies": {
		"@milkdown/prose": "catalog:editor",
		"@milkdown/transformer": "catalog:editor",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.1",
		"react-dom": "^19.2.1"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"typescript": "catalog:build"
	},
	"scripts": {
		"prepack": "bun run ../../scripts/workspace-deps/resolve-deps.ts"
	},
	"keywords": [
		"cms",
		"nuasite",
		"mdx",
		"milkdown",
		"editor",
		"react"
	]
}
