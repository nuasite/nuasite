{
	"name": "@nuasite/cms-client",
	"description": "Headless TypeScript SDK for the Nua CMS — typed client over the cms-sidecar /cms/v1 contract plus the pure entry-draft form model (zero React).",
	"files": [
		"dist/**",
		"src/**",
		"README.md",
		"package.json"
	],
	"homepage": "https://github.com/nuasite/nuasite/blob/main/packages/cms-client/README.md",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nuasite/nuasite.git",
		"directory": "packages/cms-client"
	},
	"license": "Apache-2.0",
	"version": "0.45.0",
	"module": "src/index.ts",
	"types": "src/index.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"dependencies": {
		"@nuasite/cms-types": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "catalog:build"
	},
	"peerDependencies": {
		"typescript": "catalog:build"
	},
	"scripts": {
		"prepack": "bun run ../../scripts/workspace-deps/resolve-deps.ts"
	},
	"keywords": [
		"cms",
		"nuasite",
		"client",
		"sdk",
		"headless"
	]
}
