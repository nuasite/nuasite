{
	"name": "@nuasite/astro-fragments",
	"description": "Astro integration for build-time fragment extraction. Pages emit static placeholders, fragments are rendered separately into _fragments/<hash>.html for edge composition.",
	"files": [
		"dist/**",
		"src/**",
		"components/**",
		"README.md",
		"package.json"
	],
	"homepage": "https://github.com/nuasite/nuasite/blob/main/packages/astro-fragments/README.md",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nuasite/nuasite.git",
		"directory": "packages/astro-fragments"
	},
	"license": "Apache-2.0",
	"version": "0.22.4",
	"module": "src/index.ts",
	"types": "src/index.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./Fragment.astro": "./components/Fragment.astro"
	},
	"dependencies": {
		"node-html-parser": "catalog:parsers"
	},
	"devDependencies": {
		"@types/bun": "catalog:build"
	},
	"peerDependencies": {
		"astro": "catalog:astro",
		"typescript": "catalog:build"
	},
	"scripts": {
		"prepack": "bun run ../../scripts/workspace-deps/resolve-deps.ts"
	},
	"keywords": [
		"astro",
		"fragments",
		"static",
		"edge",
		"nuasite"
	]
}
