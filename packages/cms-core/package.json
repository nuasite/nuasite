{
	"name": "@nuasite/cms-core",
	"description": "Framework-agnostic Nua CMS brain (collection scan, content-config AST, CRUD) over a FileSystem port.",
	"files": [
		"dist/**",
		"src/**",
		"README.md",
		"package.json"
	],
	"homepage": "https://github.com/nuasite/nuasite/blob/main/packages/cms-core/README.md",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nuasite/nuasite.git",
		"directory": "packages/cms-core"
	},
	"license": "Apache-2.0",
	"version": "0.46.4",
	"module": "src/index.ts",
	"types": "src/index.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"dependencies": {
		"@nuasite/cms-types": "workspace:*",
		"@babel/parser": "catalog:parsers",
		"yaml": "catalog:parsers"
	},
	"devDependencies": {
		"@babel/types": "^7.29.0",
		"@types/bun": "catalog:build"
	},
	"peerDependencies": {
		"typescript": "catalog:build",
		"@aws-sdk/client-s3": "^3.0.0"
	},
	"peerDependenciesMeta": {
		"@aws-sdk/client-s3": {
			"optional": true
		}
	},
	"scripts": {
		"prepack": "bun run ../../scripts/workspace-deps/resolve-deps.ts"
	},
	"keywords": [
		"cms",
		"nuasite",
		"headless",
		"content-collections"
	]
}
